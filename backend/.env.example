# ============================================================
# AI智能问答系统 - 环境变量配置模板
# 使用时请复制为 .env 并填入你的真实配置
# cp .env.example .env
# ============================================================

# 数据库连接（默认使用SQLite，可改为MySQL）
DATABASE_URL=sqlite:///./chat.db

# JWT密钥（生产环境请更换为随机长字符串）
SECRET_KEY=your-random-secret-key-change-me

# 大模型API配置（Anthropic Messages API兼容接口）
# 支持 DeepSeek / 硅基流动 / 智谱 等平台
AI_API_URL=https://api.deepseek.com/anthropic/v1/messages
AI_API_KEY=your-api-key-here
AI_MODEL=DeepSeek-V4-pro
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024
AI_SYSTEM_PROMPT=你是一个智能助手，请用简洁友好的方式回答用户的问题。

# 管理员账号（启动时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-to-your-own-password
